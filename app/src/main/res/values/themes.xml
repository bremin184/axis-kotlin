<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Starting theme for Splash Screen API -->
    <style name="Theme.Axis.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Axis.Main</item>
    </style>

    <!-- Main application theme -->
    <style name="Theme.Axis.Main" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
